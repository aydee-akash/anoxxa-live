# ── LiveKit Cloud (the worker connects OUTBOUND to this; no inbound ports needed) ──
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ── STT: Deepgram (Nova-3) ──
DEEPGRAM_API_KEY=

# ── TTS: Cartesia (Sonic-3) ──
CARTESIA_API_KEY=

# ── LLM: Google Gemini (native google plugin reads GOOGLE_API_KEY) ──
GOOGLE_API_KEY=

# ── Runtime profile ──
# prod = require all real keys; dev = allow the worker to boot for a structure smoke test
# without provider keys (full mock plugins arrive in Phase 1).
PROFILE=prod
